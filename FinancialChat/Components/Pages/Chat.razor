@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@inject CodexService Codex
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="chat-container">
    <button class="top-new-chat-button" type="button" title="Nuevo chat" aria-label="Nuevo chat" @onclick="StartNewConversation" disabled="@IsSending">
        <svg class="top-new-chat-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M12 3H5.5A2.5 2.5 0 0 0 3 5.5v13A2.5 2.5 0 0 0 5.5 21h13a2.5 2.5 0 0 0 2.5-2.5V12" />
            <path d="M18.4 2.8a1.9 1.9 0 0 1 2.8 2.8L11 15.8 7.5 16.5l.7-3.5 10.2-10.2Z" />
        </svg>
        <span>Nuevo chat</span>
    </button>

    <aside class="usage-panel" aria-label="Entorno de ejecución">
        <div class="usage-header">
            <span class="panel-status status @StatusClass">● @StatusText</span>
        </div>
        <div class="usage-row usage-row-main">
            <span class="usage-icon"><i class="fa-solid fa-bolt" aria-hidden="true"></i></span>
            <span class="usage-label">Tokens</span>
            <strong class="usage-value">@FormatNumber(_usage.TotalTokens)</strong>
        </div>
        <div class="usage-row">
            <span class="usage-icon"><i class="fa-solid fa-robot" aria-hidden="true"></i></span>
            <span class="usage-label">Modelo</span>
            <strong class="usage-value">@SelectedModel</strong>
        </div>
        <div class="usage-row">
            <span class="usage-icon"><i class="fa-solid fa-wallet" aria-hidden="true"></i></span>
            <span class="usage-label">Consumo</span>
            <strong class="usage-value usage-cost">@FormatMoney(_usage.EstimatedCost)</strong>
        </div>
        <div class="usage-divider"></div>
        <div class="usage-section-title">Uso de tokens</div>
        <div class="usage-row usage-row-small">
            <span class="usage-label">Entrada</span>
            <strong class="usage-value">@FormatNumber(_usage.InputTokens)</strong>
        </div>
        <div class="usage-row usage-row-small">
            <span class="usage-label">Salida</span>
            <strong class="usage-value">@FormatNumber(_usage.OutputTokens + _usage.ReasoningOutputTokens)</strong>
        </div>
    </aside>

    @if (!string.IsNullOrEmpty(Codex.AuthError))
    {
        <div class="auth-error">
            <span class="auth-icon">!</span>
            <h2>No se pudo iniciar Codex</h2>
            <p>@Codex.AuthError</p>
            <code>FinancialChat/config.json</code>
        </div>
    }
    else
    {
        <main class="chat-messages" id="messagesContainer">
            @if (!Messages.Any())
            {
                <div class="empty-state">
                    <div class="empty-mark" aria-hidden="true"></div>
                    <p class="empty-title">¿En qué puedo asistirte?</p>
                    <div class="suggestions">
                        @foreach (var s in Suggestions)
                        {
                            <button class="suggestion-chip" @onclick="() => SendSuggestion(s)">@s</button>
                        }
                    </div>
                </div>
            }

            @foreach (var msg in Messages)
            {
                <div class="message @(msg.Role == MessageRole.User ? "message-user" : "message-assistant")">
                    <div class="message-bubble">
                        @if (msg.Role == MessageRole.Assistant)
                        {
                            <div class="message-content markdown">@((MarkupString)FormatMarkdown(msg.Content))</div>
                        }
                        else
                        {
                            <div class="message-content">@msg.Content</div>
                        }
                        @if (msg.IsStreaming)
                        {
                            <span class="cursor-blink">▌</span>
                        }
                        <span class="message-time">@msg.Timestamp.ToString("HH:mm")</span>
                    </div>
                </div>
            }

            @if (IsThinking)
            {
                <div class="message message-assistant">
                    <div class="message-bubble">
                        <div class="typing-indicator"><span></span><span></span><span></span></div>
                    </div>
                </div>
            }
        </main>

        <!-- Input -->
        <footer class="chat-input-area">
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="error-bar">
                    <span>@ErrorMessage</span>
                    <button @onclick="() => ErrorMessage = string.Empty">Cerrar</button>
                </div>
            }
            <div class="input-shell">
                <textarea
                    @bind="UserInput"
                    @bind:event="oninput"
                    @onkeydown="HandleKeyDown"
                    placeholder="Formula tu pregunta"
                    rows="1"
                    disabled="@IsSending"
                    class="chat-textarea" />
                <div class="input-toolbar">
                    <div class="input-tools">
                        <button class="tool-button" type="button" title="Agregar adjunto" aria-label="Agregar adjunto">+</button>
                    </div>
                    <div class="input-meta">
                        <div class="model-picker">
                            <button class="composer-model" type="button" @onclick="ToggleModelMenu" disabled="@IsSending" aria-haspopup="listbox" aria-expanded="@IsModelMenuOpen">
                                <span>@SelectedModel</span>
                            </button>
                            @if (IsModelMenuOpen)
                            {
                                <div class="model-menu" role="listbox">
                                    @foreach (var model in Codex.AvailableModels)
                                    {
                                        <button
                                            type="button"
                                            class="model-menu-item @(model == SelectedModel ? "selected" : "")"
                                            role="option"
                                            aria-selected="@(model == SelectedModel)"
                                            @onclick="() => SelectModelAsync(model)">
                                            @model
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        <span class="connection-dot @(IsConnected ? "online" : "offline")" aria-label="@StatusText" title="@StatusText"></span>
                        <button
                            class="btn-send @(IsSending ? "sending" : "")"
                            @onclick="SendMessage"
                            disabled="@(IsSending || string.IsNullOrWhiteSpace(UserInput))">
                            @(IsSending ? "..." : "↑")
                        </button>
                    </div>
                </div>
            </div>
        </footer>
    }
</div>

@code {
    private List<ChatMessage> Messages { get; set; } = new();
    private string UserInput    { get; set; } = string.Empty;
    private bool IsSending      { get; set; } = false;
    private bool IsThinking     { get; set; } = false;
    private bool IsReady        { get; set; } = false;
    private string ErrorMessage { get; set; } = string.Empty;
    private string SelectedModel { get; set; } = string.Empty;
    private bool IsModelMenuOpen { get; set; }
    private ChatMessage? _streamingMessage;
    private CodexUsageSnapshot _usage = CodexUsageSnapshot.Empty(string.Empty);

    private bool IsConnected => IsReady || (Codex.IsRunning && string.IsNullOrEmpty(Codex.AuthError));
    private string StatusClass => IsConnected ? "online" : (string.IsNullOrEmpty(Codex.AuthError) ? "connecting" : "offline");
    private string StatusText  => IsConnected ? "Conectado" : (string.IsNullOrEmpty(Codex.AuthError) ? "Conectando..." : "Sin autenticación");

    private readonly string[] Suggestions =
    [
        "¿Cuál fue el margen neto del último trimestre?",
        "Comparar ingresos Q1 vs Q2 de este año",
        "¿Cuáles son los 5 gastos más altos del mes?",
        "Mostrar evolución de ventas de los últimos 12 meses"
    ];

    protected override void OnInitialized()
    {
        Codex.OnTokenReceived    += HandleTokenReceived;
        Codex.OnResponseComplete += HandleResponseComplete;
        Codex.OnError            += HandleError;
        Codex.OnReady            += HandleReady;
        Codex.OnUsageUpdated     += HandleUsageUpdated;
        SelectedModel = Codex.CurrentModel;
        _usage = Codex.Usage;
    }

    private async Task HandleReady()
    {
        IsReady = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleUsageUpdated(CodexUsageSnapshot usage)
    {
        _usage = usage;
        SelectedModel = usage.Model;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleTokenReceived(string token)
    {
        IsThinking = false;
        if (_streamingMessage is null)
        {
            _streamingMessage = ChatMessage.FromAssistant(isStreaming: true);
            Messages.Add(_streamingMessage);
        }
        _streamingMessage.Content += token;
        await InvokeAsync(StateHasChanged);
        await ScrollToBottomAsync();
    }

    private async Task HandleResponseComplete()
    {
        if (_streamingMessage is not null)
            _streamingMessage.IsStreaming = false;
        _streamingMessage = null;
        IsSending  = false;
        IsThinking = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleError(string error)
    {
        var assistantError = TryBuildAssistantError(error);
        if (!string.IsNullOrWhiteSpace(assistantError))
        {
            Messages.Add(ChatMessage.FromAssistant(assistantError));
            ErrorMessage = string.Empty;
        }
        else
        {
            ErrorMessage = error;
        }

        IsSending         = false;
        IsThinking        = false;
        IsReady           = false;
        _streamingMessage = null;
        await InvokeAsync(StateHasChanged);
        await ScrollToBottomAsync();
    }

    private static string? TryBuildAssistantError(string error)
    {
        if (string.IsNullOrWhiteSpace(error))
            return null;

        if (error.Contains("quota exceeded", StringComparison.OrdinalIgnoreCase)
            || error.Contains("billing", StringComparison.OrdinalIgnoreCase)
            || error.Contains("insufficient_quota", StringComparison.OrdinalIgnoreCase))
        {
            return "No puedo generar una respuesta en este momento porque se excedió la cuota o el saldo disponible de la cuenta de OpenAI. Verificá el plan, la facturación o el límite de consumo configurado y luego intentá nuevamente.";
        }

        return null;
    }

    private async Task SendMessage()
    {
        var text = UserInput.Trim();
        if (string.IsNullOrEmpty(text) || IsSending) return;

        UserInput    = string.Empty;
        IsSending    = true;
        IsThinking   = true;
        ErrorMessage = string.Empty;

        Messages.Add(ChatMessage.FromUser(text));
        StateHasChanged();
        await ScrollToBottomAsync();
        await Codex.SendMessageAsync(text);
    }

    private async Task SendSuggestion(string text)
    {
        UserInput = text;
        await SendMessage();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void ToggleModelMenu()
    {
        if (!IsSending)
            IsModelMenuOpen = !IsModelMenuOpen;
    }

    private void ClearChat()
    {
        Messages.Clear();
        _streamingMessage = null;
        IsSending  = false;
        IsThinking = false;
        ErrorMessage = string.Empty;
    }

    private async Task StartNewConversation()
    {
        if (IsSending)
            return;

        ClearChat();
        IsReady = false;
        IsSending = true;
        ErrorMessage = string.Empty;
        try
        {
            await Codex.StartNewConversationAsync();
            _usage = Codex.Usage;
        }
        finally
        {
            IsSending = false;
        }
    }

    private async Task SelectModelAsync(string model)
    {
        if (string.IsNullOrWhiteSpace(model) || model == SelectedModel)
        {
            IsModelMenuOpen = false;
            return;
        }

        IsModelMenuOpen = false;
        SelectedModel = model;
        IsReady = false;
        IsSending = true;
        IsThinking = false;
        ErrorMessage = string.Empty;
        await Codex.ChangeModelAsync(model);
        _usage = Codex.Usage;
        IsSending = false;
        IsThinking = false;
    }

    private async Task ScrollToBottomAsync()
    {
        try { await JS.InvokeVoidAsync("scrollToBottom", "messagesContainer"); }
        catch { /* ignora errores de JS durante prerender */ }
    }

    // ── Markdown básico ───────────────────────────────────────────────────────
    private static string FormatMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;

        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"```(\w*)\n?([\s\S]*?)```",
            m => $"<pre><code class=\"language-{m.Groups[1].Value}\">{System.Web.HttpUtility.HtmlEncode(m.Groups[2].Value.Trim())}</code></pre>");

        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"`([^`]+)`",
            m => $"<code>{System.Web.HttpUtility.HtmlEncode(m.Groups[1].Value)}</code>");

        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");

        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"\*(.+?)\*", "<em>$1</em>");

        text = System.Text.RegularExpressions.Regex.Replace(
            text, @"(\|.+\|\n?)+", m => ConvertTable(m.Value));

        text = text.Replace("\n", "<br/>");
        return text;
    }

    private static string ConvertTable(string raw)
    {
        var lines = raw.Trim().Split('\n').Where(l => !string.IsNullOrWhiteSpace(l)).ToList();
        if (lines.Count < 2) return raw;
        var sb = new System.Text.StringBuilder("<table class=\"data-table\">");
        for (int i = 0; i < lines.Count; i++)
        {
            var cells = lines[i].Split('|').Where(c => !string.IsNullOrWhiteSpace(c)).ToList();
            if (i == 0)
            {
                sb.Append("<thead><tr>");
                cells.ForEach(c => sb.Append($"<th>{c.Trim()}</th>"));
                sb.Append("</tr></thead><tbody>");
            }
            else if (lines[i].Contains("---")) continue;
            else
            {
                sb.Append("<tr>");
                cells.ForEach(c => sb.Append($"<td>{c.Trim()}</td>"));
                sb.Append("</tr>");
            }
        }
        sb.Append("</tbody></table>");
        return sb.ToString();
    }

    private static string FormatNumber(long value)
    {
        return value.ToString("N0", CultureInfo.InvariantCulture);
    }

    private static string FormatMoney(decimal value)
    {
        return value.ToString("$0.0000", CultureInfo.InvariantCulture);
    }

    public async ValueTask DisposeAsync()
    {
        Codex.OnTokenReceived    -= HandleTokenReceived;
        Codex.OnResponseComplete -= HandleResponseComplete;
        Codex.OnError            -= HandleError;
        Codex.OnReady            -= HandleReady;
        Codex.OnUsageUpdated     -= HandleUsageUpdated;
    }

    // En Chat.razor, bloque @code — AGREGAR esto:
    private bool _codexStarted = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_codexStarted)
        {
            _codexStarted = true;
            await Codex.StartAsync();  // Acá sí hay suscriptores para OnReady
        }
    }
}
